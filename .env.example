# Copy to .env and fill in. Never commit .env.

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small-2

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Azure Speech (TTS) — optional, enables real video narration
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_VOICE_EN=en-IN-NeerjaNeural
AZURE_SPEECH_VOICE_AR=ar-SA-ZariyahNeural

# Perplexity
PERPLEXITY_API_KEY=

# Supabase
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# App
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000

# Production CORS — comma-separated allowed origins for the API.
# Web + marketing Vercel URLs go here. *.vercel.app preview deploys are
# auto-allowed by the CORS helper in apps/api/src/main.ts.
ALLOWED_ORIGINS=https://app.superaccountant.in,https://www.superaccountant.in

# Cron secret for Supabase scheduled functions → /assignments/generate-daily.
# Falls back to NEXTAUTH_SECRET if unset.
CRON_SECRET=

# Cross-app deep linking — Vercel project settings should override these.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3001

# Optional — error reporting + analytics. Leave blank to no-op.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
