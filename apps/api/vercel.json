{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "maxDuration": 90,
      "memory": 1024,
      "excludeFiles": "**/{ffmpeg-static,resvg-js,chrome-aws-lambda,puppeteer*}/**"
    }
  },

  "rewrites": [
    { "source": "/health", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
