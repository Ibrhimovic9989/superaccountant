    "@nestjs/throttler": "^6.5.0",
    "@react-pdf/renderer": "^4.1.6",
    "@resvg/resvg-js": "^2.6.2",
    "@sa/ai": "workspace:*",
    "@sa/config": "workspace:*",
    "@sa/db": "workspace:*",
    "@sa/email": "workspace:*",
    "@sa/types": "workspace:*",
    "@types/react": "^19.0.0",
    "ffmpeg-static": "^5.2.0",
    "pino": "^9.5.0",
    "react": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsx": "^4.19.2",
    "yaml": "^2.6.1",
